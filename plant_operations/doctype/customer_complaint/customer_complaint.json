{
 "name": "Customer Complaint",
 "doctype": "DocType",
 "module": "Plant Operations",
 "autoname": "CC-.YYYY.-.#####",
 "is_submittable": 1,
 "track_changes": 1,
 "engine": "InnoDB",
 "fields": [
  {
   "fieldname": "complaint_number",
   "fieldtype": "Data",
   "label": "Complaint Number",
   "read_only": 1
  },
  {
   "fieldname": "customer",
   "fieldtype": "Link",
   "label": "Customer",
   "options": "Customer",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "sales_order",
   "fieldtype": "Link",
   "label": "Sales Order",
   "options": "Sales Order"
  },
  {
   "fieldname": "delivery_note",
   "fieldtype": "Link",
   "label": "Delivery Note",
   "options": "Delivery Note"
  },
  {
   "fieldname": "column_break_1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "complaint_type",
   "fieldtype": "Select",
   "label": "Complaint Type",
   "options": "Quality\nDamage\nShort Shipment\nWrong Item\nLate Delivery\nOther",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "status",
   "fieldtype": "Select",
   "label": "Status",
   "options": "Open\nInvestigating\nResolved\nClosed",
   "default": "Open",
   "in_list_view": 1,
   "allow_on_submit": 1
  },
  {
   "fieldname": "section_details",
   "fieldtype": "Section Break",
   "label": "Details"
  },
  {
   "fieldname": "description",
   "fieldtype": "Text",
   "label": "Description",
   "reqd": 1
  },
  {
   "fieldname": "photos",
   "fieldtype": "Attach",
   "label": "Photos"
  },
  {
   "fieldname": "column_break_2",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "received_date",
   "fieldtype": "Date",
   "label": "Received Date",
   "default": "Today"
  },
  {
   "fieldname": "reported_by",
   "fieldtype": "Data",
   "label": "Reported By"
  },
  {
   "fieldname": "section_investigation",
   "fieldtype": "Section Break",
   "label": "Investigation"
  },
  {
   "fieldname": "ncr_ref",
   "fieldtype": "Link",
   "label": "NCR Reference",
   "options": "Non-Conformance Report"
  },
  {
   "fieldname": "investigation_notes",
   "fieldtype": "Text",
   "label": "Investigation Notes"
  },
  {
   "fieldname": "section_resolution",
   "fieldtype": "Section Break",
   "label": "Resolution"
  },
  {
   "fieldname": "resolution",
   "fieldtype": "Text",
   "label": "Resolution"
  },
  {
   "fieldname": "column_break_3",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "credit_issued",
   "fieldtype": "Currency",
   "label": "Credit Issued"
  },
  {
   "fieldname": "resolved_date",
   "fieldtype": "Date",
   "label": "Resolved Date"
  }
 ],
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "submit": 1,
   "cancel": 1,
   "amend": 1,
   "print": 1,
   "export": 1,
   "report": 1
  },
  {
   "role": "Quality Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "submit": 1,
   "cancel": 1,
   "amend": 1,
   "print": 1,
   "export": 1,
   "report": 1
  },
  {
   "role": "Manufacturing User",
   "read": 1,
   "write": 1,
   "create": 1,
   "print": 1,
   "export": 1,
   "report": 1
  }
 ],
 "sort_field": "modified",
 "sort_order": "DESC"
}
